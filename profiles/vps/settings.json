{
  "env": {
    "ENABLE_TOOL_SEARCH": "true"
  },
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(bun run *)",
      "Bash(bun add *)",
      "Bash(bun install*)",
      "Bash(bunx *)",
      "Bash(bun --version*)",
      "Bash(bun create *)",
      "Bash(uv *)",
      "Bash(uvx *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git add *)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git pull*)",
      "Bash(git fetch*)",
      "Bash(git checkout*)",
      "Bash(git switch*)",
      "Bash(git restore*)",
      "Bash(git show*)",
      "Bash(git worktree*)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(gh repo *)",
      "Bash(gh api *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(mkdir -p *)",
      "Bash(touch *)",
      "Bash(cp * *)",
      "Bash(mv * *)",
      "Bash(pwd*)",
      "Bash(which *)",
      "Bash(wc *)",
      "Bash(tsc *)",
      "Bash(node *)",
      "Bash(tsx *)",
      "Bash(next dev*)",
      "Bash(next build*)",
      "Bash(next start*)",
      "Bash(next lint*)",
      "Bash(drizzle-kit *)",
      "Bash(bunx drizzle-kit *)",
      "Bash(sqlite3 *.db *)",
      "Bash(vitest *)",
      "Bash(jest *)",
      "Bash(bun test*)",
      "Bash(eslint *)",
      "Bash(prettier *)",
      "Bash(bunx prettier *)",
      "Bash(bunx eslint *)",
      "Bash(redis-cli ping*)",
      "Bash(redis-cli info*)",
      "Bash(redis-cli keys *)",
      "Bash(redis-cli get *)",
      "Bash(ps aux*)",
      "Bash(lsof *)",
      "Bash(netstat *)",
      "Bash(env | grep *)",
      "Bash(printenv *)",
      "Bash(date*)",
      "Bash(whoami*)",
      "Bash(hostname*)",
      "Bash(bun pm ls*)",
      "Bash(bun outdated*)",
      "Bash(curl -s *)",
      "Bash(curl --silent *)",
      "Bash(systemctl status *)",
      "Bash(journalctl *)",
      "Bash(docker ps*)",
      "Bash(docker logs *)",
      "Bash(docker compose *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(redis-cli flushall*)",
      "Bash(redis-cli flushdb*)",
      "Bash(git reset --hard*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(DROP TABLE*)",
      "Bash(truncate *)"
    ],
    "ask": [],
    "defaultMode": "auto"
  },
  "model": "opus",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(cat | jq -r '.tool_input.file_path // empty') && [ -n \"$FILE\" ] && (bun run format 2>/dev/null || bunx prettier --write \"$FILE\" 2>/dev/null) || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/cleanup-subagents.sh 5 >/dev/null 2>&1 || true"
          },
          {
            "type": "command",
            "command": "~/.claude/scripts/code-simplifier-gate.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": []
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"systemMessage\": \"Tip: run /claude-md-management:revise-claude-md to capture learnings into CLAUDE.md\"}'"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "n8n-mcp-skills@n8n-mcp-skills": true,
    "pg@aiguide": true,
    "learning-output-style@claude-code-plugins": true,
    "context7@claude-plugins-official": true,
    "serena@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "supabase@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "agent-sdk-dev@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "claude-mem@thedotmack": true,
    "superpowers@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  }
}
